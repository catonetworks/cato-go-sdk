  """legacy license group"""
  DUBAI
  """legacy license group"""
  EUROPE
  GROUP_1
  GROUP_2
  """legacy license group"""
  LATAM
  """legacy license group"""
  MIDDLE_EAST
  """Country with stand-alone licenses (not part of a group)"""
  MOROCCO
  """legacy license group"""
