type ZtnaAppConnectorMutations {
  "Create a new ZTNA App Connector"
  addZtnaAppConnector(input: AddZtnaAppConnectorInput!): AddZtnaAppConnectorPayload! @beta
  "Create ZTNA App Connectors configuration. Creates default ranges if not provided."
  addZtnaAppConnectorsConfiguration(input: AddZtnaAppConnectorsConfigurationInput!): AddZtnaAppConnectorsConfigurationPayload! @beta
  """
  Remove an existing ZTNA App Connector by reference
  Returns the removed resource
  """
  removeZtnaAppConnector(input: RemoveZtnaAppConnectorInput!): RemoveZtnaAppConnectorPayload! @beta
  "Remove ZTNA App Connectors configuration. Fails if any IPs are currently allocated."
  removeZtnaAppConnectorsConfiguration: RemoveZtnaAppConnectorsConfigurationPayload! @beta
  "Unassign a socket from a ZTNA App Connector"
  unassignSocketFromZtnaAppConnector(input: UnassignSocketFromZtnaAppConnectorInput!): UnassignSocketFromZtnaAppConnectorPayload! @beta
  "Update an existing ZTNA App Connector"
  updateZtnaAppConnector(input: UpdateZtnaAppConnectorInput!): UpdateZtnaAppConnectorPayload! @beta
  "Update ZTNA App Connectors configuration."
  updateZtnaAppConnectorsConfiguration(input: UpdateZtnaAppConnectorsConfigurationInput!): UpdateZtnaAppConnectorsConfigurationPayload! @beta
  upgradeZtnaAppConnector(input: UpgradeZtnaAppConnectorInput!): UpgradeZtnaAppConnectorPayload! @beta
}

type ZtnaAppConnector {
  "When the ZTNA App Connector was created"
  createdAt: DateTime
  "Optional description of the ZTNA App Connector (max 250 characters)"
  description: String
  "name of the ZTNA App Connector group"
  groupName: String!
  "The unique ID of the ZTNA App Connector"
  id: ID!
  "Whether the ZTNA App Connector socket is registered"
  isRegistered: Boolean!
  "Physical location of the connector"
  location: ZtnaAppConnectorLocation!
  "The unique name of the ZTNA App Connector"
  name: String!
  "Preferred PoP locations settings"
  preferredPopLocation: ZtnaAppConnectorPreferredPopLocation
  "Number of private applications associated with this connector's group"
  privateAppCount: Int!
  "List of private applications associated with this connector"
  privateAppRef: [PrivateApplicationRef!]!
  "Unique serial number of the ZTNA App Connector"
  serialNumber: String
  "Unique socket ID of the ZTNA App Connector"
  socketId: ID
  "Socket model of the ZTNA App Connector"
  socketModel: SocketModel
  "Connector type"
  type: ZtnaAppConnectorType!
}

type ZtnaAppConnectorLocation {
  "address"
  address: String
  "city name"
  cityName: String!
  "country code"
  countryCode: String!
  "country name"
  countryName: String
  "state code"
  stateCode: String
  "time zone"
  timezone: TimeZone!
}

"""Input for creating a new ZTNA App Connector"""
input AddZtnaAppConnectorInput {
  "Optional description of the ZTNA App Connector (max 250 characters)"
  description: String
  "name of the ZTNA App Connector group. if not exists, it will be created"
  groupName: String!
  "Physical location of the connector"
  location: ZtnaAppConnectorLocationInput!
  name: String!
  """Preferred PoP locations settings"""
  preferredPopLocation: ZtnaAppConnectorPreferredPopLocationInput! = {preferredOnly: false, automatic: true}
  "Connector type"
  type: ZtnaAppConnectorType!
}

input UpdateZtnaAppConnectorInput {
  "Optional description of the ZTNA App Connector (max 250 characters)"
  description: String
  "name of the ZTNA App Connector group. if not exists, it will be created"
  groupName: String
  "The unique ID of the ZTNA App Connector"
  id: ID!
  "Physical location of the connector"
  location: ZtnaAppConnectorLocationInput
  "The unique name of the ZTNA App Connector"
  name: String
  "Preferred PoP locations settings"
  preferredPopLocation: ZtnaAppConnectorPreferredPopLocationInput
}

input ZtnaAppConnectorLocationInput {
  "optional address"
  address: String
  "city name, must belong to the country or country and state"
  city: String!
  "country code"
  countryCode: String!
  "optional state code"
  stateCode: String
  "time zone"
  timezone: TimeZone!
}

