  """
  retrieveUsedVlanIDs(input: RetrieveUsedVlanIDsInput!): RetrieveUsedVlanIDsPayload @beta
  """Retrieves details of a specific secondary AWS vSocket."""
  secondaryAwsVSocket(socketId: ID!): SecondaryAwsVSocket @beta
  """Retrieves details of a specific secondary Azure vSocket."""
  secondaryAzureVSocket(socketId: ID!): SecondaryAzureVSocket @beta
  secondaryGcpVSocket(input: SecondaryGcpVSocketInput!): SecondaryGcpVSocketPayload @rollout @beta
  """Fetch backhauling configuration for a site."""
  siteBackhauling(site: SiteRefInput!): SiteBackhaulingPayload @beta
  """
  Provides the BGP status of the specified site, including session and route details.
  """
  siteBgpStatus(input: SiteBgpStatusInput!): SiteBgpStatus @beta
  siteGeneralDetails(site: SiteRefInput!): SiteGeneralDetailsPayload @beta
  siteSocketConfiguration(input: SiteSocketConfigurationInput!): SiteSocketConfiguration @beta
  networkRangeList(input: NetworkRangeListInput!): NetworkRangeListPayload
  networkRange(networkRangeId: ID!): NetworkRange
  """Retrieve a single static host configured on a site by its ID."""
  staticHost(site: SiteRefInput!, hostId: ID!): StaticHostPayload @beta
  """Retrieve all static hosts configured on a site."""
  staticHostList(site: SiteRefInput!): StaticHostListPayload @beta
  validateWifiRadioProfile(input: ValidateWifiRadioProfileInput!): ValidateWifiRadioProfilePayload @rollout @beta
  validateWifiRadioProfileByCountry(input: ValidateWifiRadioProfileByCountryInput!): ValidateWifiRadioProfilePayload @rollout @beta
  validWifiRadioSettings(input: ValidWifiRadioSettingsInput!): ValidWifiRadioSettingsPayload @rollout @beta
  validWifiRadioSettingsByCountry(input: ValidWifiRadioSettingsByCountryInput!): ValidWifiRadioSettingsPayload @rollout @beta
  wifiRadioProfile(input: WifiRadioProfileRefInput!): WifiRadioProfile @rollout @beta
  wifiRadioProfileBySite(input: SiteRefInput!): WifiRadioProfile @rollout @beta
