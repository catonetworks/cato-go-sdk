  EMAIL_ADDRESS
  FILE
  HASH
  IP
  MAILBOX
  METRIC
  OS
  OTHER
  URL
  USER_AGENT
}

interface Endpoint implements MergedIncident {
  """Unique Cato ID for the story"""
