  ready
}

enum HaSubStatus {
  fail
  ok
}

enum ConnectivityStatus {
  """Connected to the Cato Cloud"""
  connected
  """Disconnected from the Cato Cloud"""
  disconnected
}

enum OperationalStatus {
  """Passing traffic"""
  active
  """Disabled in the Cato Management Application"""
  disabled
  """License has expired for this site and you can't configure it"""
  locked
  """After you create the site before it is connected to the Cato Cloud"""
  new
  "For VPN users only"
  pending_code_generation
  "For VPN users only"
  pending_mfa_configuration
  "For VPN users only"
  pending_user_configuration
}

type UserSnapshot {
  """
  In this state the client does not create its own connection, but reuses
  the Office's socket connection
  """
  connectedInOffice: Boolean
  """Connectivity to the Cato Cloud"""
  connectivityStatus: ConnectivityStatus
  "The host name of the device"
  deviceName: String
  """Data related to the Client"""
  devices: [DeviceSnapshot!]
  """VPN user ID"""
  id: ID
  """General information about the VPN user"""
  info: UserInfo
  """IP address of the PoP that the Client is connected to"""
  internalIP: String
  "Last time the user was connected (relevant if not currently connected)"
  lastConnected: DateTime
  "User name from configuration, same as info.name"
  name: String
  """Status for a site or VPN user"""
  operationalStatus: OperationalStatus
  """Operating system of the device the Client is running on"""
  osType: String
  """Version of the operating system for the device"""
  osVersion: String
  """ID of the PoP that the Client is connected to"""
  popID: Int
  """Name of the PoP that the VPN user is connected to"""
  popName: String
  """Data related to the most recent completed VPN connections"""
  recentConnections: [RecentConnection!]
  """IP address of the Client"""
  remoteIP: String
  """IP address, ISP, and geographical information related to the Client"""
  remoteIPInfo: IPInfo
  "How long has the user been connected (in seconds)"
  uptime: Int
  "VPN client version string"
  version: String
  "VPN client version number"
  versionNumber: Int
}

type SiteSnapshot {
  """Alternative WAN connectivity status"""
  altWanStatus: String
  """For connected sites, since when are they connected"""
  connectedSince: DateTime
  """Connectivity to the Cato Cloud"""
  connectivityStatus: ConnectivityStatus
  """Degraded status and details"""
  degradedStatus: DegradedStatus
  """Data related to the Sockets for a site"""
  devices: [DeviceSnapshot!]
  """Site HA readiness information"""
  haStatus: HaStatus
  """Number of hosts connected to a site"""
  hostCount: Int
  """site ID"""
  id: ID
  """General real-time information about the site"""
  info: SiteInfo
  """
  Relevant when the site is disconnected - the last time the device was connected
  """
  lastConnected: DateTime
  """Status for a site or VPN user"""
  operationalStatus: OperationalStatus
  """Name of the PoP that the site is connected to"""
  popName: String
  protoId: ID
}

enum DegradedStatusReason {
  ALT_WAN_DISCONNECTED
  CROSS_CONNECT_CIRCUIT_DISCONNECTED
  HA_NOT_READY_INCOMPATIBLE_MAJOR_SOCKET_VERSIONS
  HA_NOT_READY_NO_KEEPALIVE
  HA_NOT_READY_SOCKET_DISCONNECTED
  IPSEC_MULTI_TUNNEL_TUNNEL_DISCONNECTED
  IPSEC_TUNNEL_DISCONNECTED
  LAN_DISCONNECTED
  LAN_LAG_DISCONNECTED
  LAN_LAG_MEMBER_DISCONNECTED
  WAN_DISCONNECTED
  WAN_TUNNEL_DISCONNECTED
}

type DegradedStatus {
  degradedDetails: [DegradedDetail!]!
  isDegraded: Boolean!
}

type DegradedDetail {
  args: DegradedStatusArgs
  reason: DegradedStatusReason!
}

union DegradedStatusArgs = DegradedStatusSocketVersionsArgs | DegradedStatusBasicDataArgs | DegradedStatusSocketArgs | DegradedStatusLastConnectedArgs | DegradedStatusMultiTunnelArgs

type DegradedStatusLastConnectedArgs {
  lastConnectedDate: DateTime
}

type DegradedStatusBasicDataArgs {
  deviceName: String!
  lastConnectedDate: DateTime
}

type DegradedStatusSocketArgs {
  deviceName: String!
  lastConnectedDate: DateTime
  portID: ID!
  portName: String!
}

type DegradedStatusSocketVersionsArgs {
  primaryVersion: String!
  secondaryVersion: String!
}

type DegradedStatusMultiTunnelArgs {
  deviceName: String!
  lastConnectedDate: DateTime
  tunnelID: ID!
  tunnelName: String!
}

enum BgpState {
  Active
  Connect
  Established
  Idle
  OpenConfirm
  OpenSent
  StateMAX
}

type ConnectivitySnapshotsQueries {
  """Returns ZTNA app connector group snapshots"""
  ztnaAppConnectorGroupSnapshot(input: ZtnaAppConnectorGroupSnapshotInput!): ZtnaAppConnectorGroupSnapshotPayload @beta
  """Returns ZTNA app connector snapshots"""
  ztnaAppConnectorSnapshot(input: ZtnaAppConnectorSnapshotInput!): ZtnaAppConnectorSnapshotPayload @beta
  """Returns summary metrics for ZTNA app connector snapshots"""
  ztnaAppConnectorSnapshotSummary(input: ZtnaAppConnectorSnapshotSummaryInput!): ZtnaAppConnectorSnapshotSummaryPayload @beta
}

input ZtnaAppConnectorGroupSnapshotInput {
  """Filters applied to app connector group snapshots"""
  filter: ZtnaAppConnectorGroupSnapshotFilterInput
  """Paging configuration for the result set"""
  paging: PagingInput = {limit: 100, from: 0}
}

input ZtnaAppConnectorGroupSnapshotFilterInput {
  """
  Filters groups where at least one connector has a matching connected PoP
  """
  connectedPop: [StringFilterInput!]
  """
  Filters groups where at least one connector has a matching connectivity status
  """
  connectivityStatus: [ZtnaAppConnectorConnectivityStatusFilterInput!]
  """
  Filters groups where at least one connector has a matching connector name
  """
  connectorName: [StringFilterInput!]
  """
  Filters groups where at least one connector has a matching country code
  """
  country: [StringFilterInput!]
  """
  Filters groups where at least one connector has a matching country name
  """
  countryName: [StringFilterInput!]
  """
  Filters groups where at least one connector has a matching device version
  """
  deviceVersion: [StringFilterInput!]
  """Filters groups where at least one connector has a matching DNS server"""
  dnsServer: [StringFilterInput!]
  """Performs free-text filtering across connector fields"""
  freeText: [FreeTextFilterInput!]
  """Filters groups by group name"""
  groupName: [StringFilterInput!]
  """
  Filters groups where at least one connector has a matching connector ID
  """
  id: [IdFilterInput!]
  """
  Filters groups where at least one connector has a matching LAN IP address
  """
  lanIp: [StringFilterInput!]
  """
  Filters groups where at least one connector has a matching socket model
  """
  model: [ZtnaAppConnectorModelFilterInput!]
  """
  Filters groups where at least one connector is associated with a matching private application
  """
  privateApp: [StringFilterInput!]
  """
  Filters groups where at least one connector has a matching serial number
  """
  serialNumber: [StringFilterInput!]
}

input ZtnaAppConnectorSnapshotInput {
  """Filters applied to app connector snapshots"""
  filter: ZtnaAppConnectorSnapshotFilterInput
  """Paging configuration for the result set"""
  paging: PagingInput = {limit: 100, from: 0}
  """Sorting applied to app connector snapshots"""
  sort: ZtnaAppConnectorSnapshotSortInput
}

input ZtnaAppConnectorSnapshotFilterInput {
  """Filters snapshots by connected PoP"""
  connectedPop: [StringFilterInput!]
  """Filters snapshots by connectivity status"""
  connectivityStatus: [ZtnaAppConnectorConnectivityStatusFilterInput!]
  """Filters snapshots by connector name"""
  connectorName: [StringFilterInput!]
  """Filters snapshots by country code"""
  country: [StringFilterInput!]
  """Filters snapshots by country name"""
  countryName: [StringFilterInput!]
  """Filters snapshots by device version"""
  deviceVersion: [StringFilterInput!]
  """Filters snapshots by DNS server"""
  dnsServer: [StringFilterInput!]
  """Performs free-text filtering across supported fields"""
  freeText: [FreeTextFilterInput!]
  """Filters snapshots by group name"""
  groupName: [StringFilterInput!]
  """Filters snapshots by connector ID"""
  id: [IdFilterInput!]
  """Filters snapshots by LAN IP address"""
  lanIp: [StringFilterInput!]
  """Filters snapshots by socket model"""
  model: [ZtnaAppConnectorModelFilterInput!]
  """Filters snapshots by private application name"""
  privateApp: [StringFilterInput!]
  """Filters snapshots by serial number"""
  serialNumber: [StringFilterInput!]
}

input ZtnaAppConnectorSnapshotSortInput {
  """Sorts snapshots by connectivity state"""
  connectivity: SortOrderInput
  """Sorts snapshots by connector creation time"""
  createdAt: SortOrderInput
  """Sorts snapshots by connector name"""
  name: SortOrderInput
}

input ZtnaAppConnectorSnapshotSummaryInput {
  """Filters applied to the snapshot summary"""
  filter: ZtnaAppConnectorSnapshotSummaryFilterInput
}

input ZtnaAppConnectorSnapshotSummaryFilterInput {
  """Filters the summary by connectivity status"""
  connectivityStatus: [ZtnaAppConnectorConnectivityStatusFilterInput!]
}

input ZtnaAppConnectorConnectivityStatusFilterInput {
  """Matches an exact connectivity status"""
  eq: ZtnaAppConnectorConnectivityStatus
  """Matches any of the provided connectivity statuses"""
  in: [ZtnaAppConnectorConnectivityStatus!]
  """Excludes an exact connectivity status"""
  neq: ZtnaAppConnectorConnectivityStatus
  """Excludes all provided connectivity statuses"""
  nin: [ZtnaAppConnectorConnectivityStatus!]
}

input ZtnaAppConnectorModelFilterInput {
  """Matches an exact socket model"""
  eq: SocketModel
  """Matches any of the provided socket models"""
  in: [SocketModel!]
  """Excludes an exact socket model"""
  neq: SocketModel
  """Excludes all provided socket models"""
  nin: [SocketModel!]
}

type ZtnaAppConnectorGroupSnapshotPayload {
  """App connector group snapshot items in the current page"""
  items: [ZtnaAppConnectorGroupSnapshot!]!
  """Paging information for the current result set"""
  pageInfo: PageInfo!
}

type ZtnaAppConnectorGroupSnapshot {
  """Connectivity status breakdown for the group"""
