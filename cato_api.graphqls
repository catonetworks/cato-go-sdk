  """Vat id (required for Brazil)"""
  vatId: String
}

input EnterpriseDirectoryLocationListInput {
  filter: LocationFilterInput
  paging: PagingInput = {limit: 100, from: 0}
  sort: LocationSortInput = {name: {direction: ASC, priority: 1}}
}

