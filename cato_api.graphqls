  fields: [EventField!]
  "fields in map format (see Map scalar)"
  fieldsMap: Map
  fieldsUnitTypes: [UnitType!]
  """
  Simplified fields, as array of name value tuples, e.g: [ [ "name", "val" ], [ "name2", "val2" ] ... ]
  """
  flatFields: [[String!]]
  prevTimeFrame: Map
  trends: Map
}

